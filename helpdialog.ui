       <height>252</height>
      </size>
     </property>
     <property name="readOnly">
      <bool>true</bool>
     </property>
     <property name="html">
      <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;meta charset=&quot;utf-8&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
hr { height: 1px; border-width: 0; }
li.unchecked::marker { content: &quot;\2610&quot;; }
li.checked::marker { content: &quot;\2612&quot;; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Sans Serif'; font-size:9pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;Die &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-weight:700;&quot;&gt;Kühlgrenztemperatur &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;(auch &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-style:italic;&quot;&gt;Feuchtkugeltemperatur &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;genannt) ist die tiefste Temperatur, die durch reine Verdunstungskühlung in einer bestimmten Umgebung erreicht werden kann. Sie hängt maßgeblich von der Lufttemperatur und der Luftfeuchtigkeit ab: Je trockener die Luft, desto stärker ist der Kühleffekt.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;Für den menschlichen Körper ist die Kühlgrenztemperatur ein&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-style:italic;&quot;&gt; zentraler Indikator für Hitzestress&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;. Der Körper reguliert seine Temperatur bei Hitze durch Schwitzen. Die Verdunstung des Schweißes auf der Haut erzeugt dabei Kälte.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-weight:700;&quot;&gt;Das Limit:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt; Liegt die Kühlgrenztemperatur &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-style:italic;&quot;&gt;bei 35 °C oder darüber&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;, kann die Umgebung keine Feuchtigkeit mehr aufnehmen. Der Schweiß verdunstet nicht mehr, und der Körper kann sich nicht mehr abkühlen.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;Für einen gesunden, ruhenden Menschen ist dieser Wert nach etwa sechs Stunden lebensgefährlich.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-weight:700;&quot;&gt;Gefühlte Temperatur:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt; Die Kühlgrenztemperatur liegt meist deutlich unter der eigentlichen Lufttemperatur. Bei 30 °C Lufttemperatur und 50 % relativer Luftfeuchtigkeit beträgt die Kühlgrenztemperatur beispielsweise rund 22 °C.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;Neben der Humanbiologie und Meteorologie ist die Kühlgrenztemperatur eine wichtige Kenngröße in der Klima- und Trocknungstechnik.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;Zur &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-weight:700;&quot;&gt;Berechnung &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;verwendet man meist die empirische Formel nach Roland Stull, da sie die Lufttemperatur und die relative Luftfeuchtigkeit exakt in Beziehung setzt.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;Die im Programm verwendete &lt;/span&gt;&lt;a href=&quot;https://de.wikipedia.org/wiki/K%C3%BChlgrenztemperatur&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; text-decoration: underline; color:#1f9b5d;&quot;&gt;Stull-Formel &lt;/span&gt;&lt;/a&gt;&lt;span style=&quot; font-family:'Segoe UI';&quot;&gt;gilt für Lufttemperaturen zwischen -20 °C und 50 °C sowie einer relativen Luftfeuchtigkeit zwischen 5 % und 99 % bei normalem Luftdruck.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Segoe UI';&quot;&gt;&lt;br /&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
